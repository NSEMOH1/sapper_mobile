{
  "expo": {
    "name": "Sappers",
    "slug": "sappers",
    "version": "1.0.0",
    "scheme": "sappers",
    "orientation": "portrait",
    "icon": "./assets/icons/icon.png",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.sappers.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icons/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "versionCode": 1,
      "predictiveBackGestureEnabled": false,
      "package": "com.sappers.app"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/icons/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#00612c",
          "image": "./assets/icons/splash.png",
          "resizeMode": "contain",
          "dark": {
            "image": "./assets/icons/splash.png",
            "backgroundColor": "#00612c"
          },
          "imageWidth": 629
        }
      ],
      "expo-image",
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "ec2f1e26-0110-42e9-b64b-f417c2b16909"
      }
    }
  }
}
